# Telegram
BOT_TOKEN=your_telegram_bot_token

# Bot owner (only this user gets full DM access)
OWNER_ID=1776244625

# Gemini API keys (one per GCP project, used in order)
GEMINI_API_KEY_1=your_first_project_api_key
GEMINI_API_KEY_2=your_second_project_api_key

# Rate limits
RPM_LIMIT=15
RPD_PER_MODEL=1000

# Default batch interval for group moderation (seconds, 0 = each message separately)
DEFAULT_BATCH_INTERVAL=30

# Database path
DATABASE_PATH=data/bot.db
